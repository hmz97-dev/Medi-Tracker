{% extends 'base.html.twig' %}

{% block title %}Patient{% endblock %}

{% block body %}
    <h1>Patient</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ patient.id }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ patient.FirstName }}</td>
            </tr>
            <tr>
                <th>LastName</th>
                <td>{{ patient.LastName }}</td>
            </tr>
            <tr>
                <th>DateNaissance</th>
                <td>{{ patient.dateNaissance ? patient.dateNaissance|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Gender</th>
                <td>{{ patient.Gender }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ patient.Email }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ patient.Description }}</td>
            </tr>
            <tr>
                <th>Adress</th>
                <td>{{ patient.Adress }}</td>
            </tr>
            <tr>
                <th>BloodGroup</th>
                <td>{{ patient.BloodGroup }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_patient_index') }}">back to list</a>

    <a href="{{ path('app_patient_edit', {'id': patient.id}) }}">edit</a>

    {{ include('patient/_delete_form.html.twig') }}
{% endblock %}
