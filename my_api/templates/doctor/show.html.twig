{% extends 'base.html.twig' %}

{% block title %}Doctor{% endblock %}

{% block body %}
    <h1>Doctor</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ doctor.id }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ doctor.firstName }}</td>
            </tr>
            <tr>
                <th>LastName</th>
                <td>{{ doctor.lastName }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ doctor.Email }}</td>
            </tr>
            <tr>
                <th>PhoneNumber</th>
                <td>{{ doctor.PhoneNumber }}</td>
            </tr>
            <tr>
                <th>Speciality</th>
                <td>{{ doctor.Speciality }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ doctor.Description }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_doctor_index') }}">back to list</a>

    <a href="{{ path('app_doctor_edit', {'id': doctor.id}) }}">edit</a>

    {{ include('doctor/_delete_form.html.twig') }}
{% endblock %}
